  "keyFeatures": [
    "Internationalization (i18n) with English and Spanish support",
    "Dark mode toggle with persistent theme preferences",
    "Glassmorphism design with backdrop blur and gradients",
    "Scroll-reveal animations with staggered delays",
    "Privacy-first contact cards (click to reveal)",
    "Language-aware CV download",
    "Timeline layouts for education and experience",
    "Fully responsive mobile-first design"
  ],
  "publicApiSurface": [
    "Hero.astro - Main hero section with profile and CTA",
    "About.astro - Certifications, education, and experience timelines",
    "Projects.astro - Cloud solutions section",
    "CaseStudyCard.astro - Narrative case study card component",
    "Skills.astro - Technical skills, soft skills, and languages",
    "Contact.astro - Privacy-first contact section",
    "Navbar.astro - Navigation bar with language/theme toggles",
    "Footer.astro - Footer with copyright",
    "ThemeToggle.astro - Light/dark mode toggle",
    "LanguageSelector.astro - Language switcher (ES/EN)",
    "Layout.astro - Global layout with scroll-reveal system",
    "i18n/utils.ts - Translation utilities and strings"
  ]
}
